                            <HBox class="filtersToolbar" width="100%">
                                <Text text="Filters:" class="filtersLabel"/>
                                <HBox class="filterPill pillBlue"   alignItems="Center" justifyContent="Center"><Text text="Domain · All"        class="pillBlueText"/></HBox>
                                <HBox class="filterPill pillRed"    alignItems="Center" justifyContent="Center"><Text text="Severity · Hard + Soft" class="pillRedText"/></HBox>
                                <HBox class="filterPill pillYellow" alignItems="Center" justifyContent="Center"><Text text="Score · 65–84"       class="pillYellowText"/></HBox>
                                <HBox class="filterPill pillCyan"   alignItems="Center" justifyContent="Center"><Text text="Source · All 6"      class="pillCyanText"/></HBox>
                                <HBox class="filterPill pillGreen"  alignItems="Center" justifyContent="Center"><Text text="Owner · Me"          class="pillGreenText"/></HBox>
                                <HBox class="filterPill pillAdd"    alignItems="Center" justifyContent="Center"><Text text="+ Add filter"        class="pillAddText"/></HBox>
                                <ToolbarSpacer/>
                                <HBox class="pillDropdown" alignItems="Center" justifyContent="Center">
                                    <core:Icon src="sap-icon://bookmark" class="dropdownIcon"/>
                                    <Text text="My weekday queue" class="dropdownText"/>
                                    <core:Icon src="sap-icon://slim-arrow-down" class="dropdownIcon"/>
                                </HBox>
                            </HBox>

                            <VBox class="tableContainer">
                                <Table id="stewardInboxTable" mode="MultiSelect" items="{inbox>/items}"
                                       selectionChange="onSelectionChange" class="stewardTable">
                                    <columns>
                                        <Column width="180px"><Text text="RECORD"      class="columnHeader"/></Column>
                                        <Column width="110px"><Text text="DOMAIN"      class="columnHeader"/></Column>
                                        <Column width="100px"><Text text="SOURCE"      class="columnHeader"/></Column>
                                        <Column width="140px"><Text text="SCORE"       class="columnHeader"/></Column>
                                        <Column>             <Text text="TOP FINDING"  class="columnHeader"/></Column>
                                        <Column width="95px"><Text text="SEV"          class="columnHeader"/></Column>
                                        <Column width="85px"><Text text="AGE"          class="columnHeader"/></Column>
                                        <Column width="50px" hAlign="End"><Text text="" class="columnHeader"/></Column>
                                    </columns>
                                    <items>
                                        <ColumnListItem selected="{inbox>selected}" class="tableRow">
                                            <cells>
                                                <VBox class="recordCell">
                                                    <Link text="{inbox>id}"   class="recordCodeLink"/>
                                                    <Text text="{inbox>name}" class="recordSubTitle"/>
                                                </VBox>
                                                <core:HTML content="{= '&lt;div class=&quot;domainDotHbox&quot;&gt;&lt;span class=&quot;domainDot ' + ${inbox>domainDot} + 'Dot&quot;&gt;&amp;#9679;&lt;/span&gt;&lt;span class=&quot;cellText&quot;&gt;' + ${inbox>domain} + '&lt;/span&gt;&lt;/div&gt;' }"/>
                                                <Text text="{inbox>source}" class="cellText"/>
                                                <core:HTML content="{= '&lt;div class=&quot;scoreContainerHTML&quot;&gt;&lt;div class=&quot;scoreBoxVal ' + ${inbox>scoreClass} + 'Bg&quot;&gt;' + ${inbox>score} + '&lt;/div&gt;&lt;div class=&quot;scoreIndicatorCol&quot;&gt;&lt;div class=&quot;scoreSliderBase&quot;&gt;&lt;div class=&quot;scoreSliderActive ' + ${inbox>scoreClass} + 'Bg&quot; style=&quot;width: ' + ${inbox>score} + '%;&quot;&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;scoreStateText&quot;&gt;' + ${inbox>scoreState} + '&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;' }"/>
                                                <Text text="{inbox>finding}" class="cellText boldFinding"/>
                                                <core:HTML content="{= '&lt;div class=&quot;sevDotHbox&quot;&gt;&lt;span class=&quot;sevDot ' + ${inbox>sevDot} + 'Dot&quot;&gt;&amp;#9679;&lt;/span&gt;&lt;span class=&quot;cellText boldSev&quot;&gt;' + ${inbox>sev} + '&lt;/span&gt;&lt;/div&gt;' }"/>
                                                <Text text="{inbox>age}" class="cellText ageText"/>
                                                <Button icon="sap-icon://overflow" type="Transparent" class="rowActionBtn"/>
                                            </cells>
                                        </ColumnListItem>
                                    </items>
                                </Table>
                                <OverflowToolbar class="tableFooterToolbar">
                                    <Text text="Showing 1–10 of 142" class="footerLeftText"/>
                                    <ToolbarSpacer/>
                                    <HBox class="paginationContainer" alignItems="Center">
                                        <Button text="&lt;" class="pagBtn pagArrow"/>
                                        <Button text="1"   class="pagBtn pagActive"/>
                                        <Button text="2"   class="pagBtn"/>
                                        <Button text="3"   class="pagBtn"/>
                                        <Button text="4"   class="pagBtn"/>
                                        <Button text="5"   class="pagBtn"/>
                                        <Button text="&gt;" class="pagBtn pagArrow"/>
                                    </HBox>
                                </OverflowToolbar>
                            </VBox>
                        </VBox>

                        <!-- ══════════ MANAGE APPROVAL VIEW ══════════ -->
                        <VBox id="manageApprovalView" visible="false" width="100%" class="inboxContainer">
                            <HBox class="inboxBreadcrumbs">
                                <Link text="Foundation" class="breadcrumbBaseLink" press="onDashboardPress"/>
                                <Text text=" › " class="breadcrumbDivider"/>
                                <Text text="Manage Approval" class="breadcrumbCurrent"/>
                            </HBox>

                            <HBox justifyContent="SpaceBetween" alignItems="Center" width="100%" class="inboxTitleBar">
                                <HBox alignItems="Center">
                                    <Title text="Manage Approval" level="H1" class="inboxTitleText"/>
                                    <Text text="{approval>/count} workflows" class="inboxCountText"/>
                                </HBox>
                            </HBox>

                            <VBox class="tableContainer">
                                <Table id="manageApprovalTable" items="{approval>/items}" class="stewardTable">
                                    <columns>
                                        <Column width="200px"><Text text="Workflow Name" class="columnHeader"/></Column>
                                        <Column width="110px"><Text text="Level 1"        class="columnHeader"/></Column>
                                        <Column width="160px"><Text text="Name"           class="columnHeader"/></Column>
                                        <Column width="150px"><Text text="Requestor"      class="columnHeader"/></Column>
                                        <Column>             <Text text="Users"           class="columnHeader"/></Column>
                                    </columns>
                                    <items>
                                        <ColumnListItem class="tableRow">
                                            <cells>
                                                <Text text="{approval>workflow}" class="cellText recordCodeLink"/>
                                                <Text text="{approval>level}"    class="cellText"/>
                                                <Text text="{approval>name}"     class="cellText"/>
                                                <Text text="{approval>requestor}" class="cellText"/>
                                                <Text text="{approval>users}"    class="cellText"/>
                                            </cells>
                                        </ColumnListItem>
                                    </items>
                                </Table>
                            </VBox>
                        </VBox>

                    </ScrollContainer>
                </VBox>

            </HBox>
        </VBox>

        <!-- MasterCreate full-screen overlay — shown/hidden without routing -->
        <core:HTML id="masterCreateOverlay" preferDOM="true"
            content="&lt;div id='masterCreateOverlayRoot' style='display:none;position:fixed;inset:0;z-index:9999;background:#EDF2F7;overflow:auto;'&gt;&lt;/div&gt;"/>
    </Page>
</mvc:View>
