{
  "dependencies": {
    "@cap-js/postgres": "^2",
    "@cap-js/sqlite": "^2.4.0",
    "@sap/xssec": "^4.13.0",
    "passport": "^0.7.0"
  },
  "devDependencies": {
    "sqlite3": "^6.0.1"
  },
  "scripts": {
    "start": "cds-serve",
    "dev": "cds watch --profile dev",
    "build": "mbt build",
